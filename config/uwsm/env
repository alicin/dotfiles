# UWSM session environment for Hyprland.
# Sourced by uwsm before starting the compositor, then exported to the
# systemd --user and D-Bus activation environments.

# Apps.
export TERMINAL="kitty"
export EDITOR="code"
export FILE_BROWSER="yazi"
export BROWSER="google-chrome-stable"
export MOZ_ENABLE_WAYLAND="1"

# Backends.
export SDL_VIDEODRIVER="wayland"
export CLUTTER_BACKEND="wayland"

# Qt.
export QT_QPA_PLATFORM="wayland;xcb"
export QT_AUTO_SCREEN_SCALE_FACTOR="1"
export QT_SCALE_FACTOR="1"
export QT_WAYLAND_DISABLE_WINDOWDECORATION="1"
export QT_QPA_PLATFORMTHEME="qt5ct"

# GDK / GTK.
export GDK_SCALE="1"
export GDK_BACKEND="wayland,x11,*"
export GSK_RENDERER="ngl"

# Electron.
export ELECTRON_OZONE_PLATFORM_HINT="wayland"

# XDG.
export XDG_CURRENT_DESKTOP="Hyprland"
export XDG_SESSION_TYPE="wayland"
export XDG_SESSION_DESKTOP="Hyprland"

# Cursor theme.
export HYPRCURSOR_THEME="rose-pine-hyprcursor"
export HYPRCURSOR_SIZE="32"
export XCURSOR_THEME="BreezeX-RosePine-Linux"
export XCURSOR_SIZE="32"

# ── GPU: mode-aware environment ─────────────────────────────────────────────
# Re-evaluated at every login. A supergfx mode switch (`supergfxctl -m ...`)
# always logs you out, so the right GPU setup is picked automatically on the way
# back in -- no daemon/hook needed.
#
# AQ_DRM_DEVICES (the compositor's GPU) MUST stay colon-free: it is ':'-delimited,
# and a by-path name contains colons -> Aquamarine "Found no gpus" -> crash loop.
# We point it at the colon-free ~/.config/hypr/igpu symlink (-> Intel card via the
# udev by-path link), which also survives card0/card1 renumbering.
#
# Game-GPU policy (chosen 2026-06-25):
#   Integrated / Vfio  -> dGPU unavailable; force everything onto the Intel iGPU.
#   Hybrid             -> games default to the nvidia dGPU (PRIME offload);
#                         compositor and video decode stay on the iGPU.
#   AsusMuxDgpu        -> nvidia drives the panel directly; everything on nvidia.
# Per-app override either way: `igpu-run <cmd>` / `dgpu-run <cmd>`.
_gfx="$(/usr/bin/supergfxctl -g 2>/dev/null)"
case "$_gfx" in
  Integrated|Vfio)
    export AQ_DRM_DEVICES="$HOME/.config/hypr/igpu"
    export MESA_VK_DEVICE_SELECT="8086:7d51!"     # Vulkan (DXVK/vkd3d) -> Intel
    export __GLX_VENDOR_LIBRARY_NAME="mesa"        # GLX -> Intel
    export DRI_PRIME=0
    export LIBVA_DRIVER_NAME="iHD"                 # VA-API video -> Intel
    unset __NV_PRIME_RENDER_OFFLOAD __VK_LAYER_NV_optimus
    ;;
  AsusMuxDgpu)
    unset AQ_DRM_DEVICES                           # nvidia drives the panel (MUX)
    export __GLX_VENDOR_LIBRARY_NAME="nvidia"
    export LIBVA_DRIVER_NAME="nvidia"
    unset MESA_VK_DEVICE_SELECT DRI_PRIME __NV_PRIME_RENDER_OFFLOAD __VK_LAYER_NV_optimus
    ;;
  *)  # Hybrid (and any unrecognized mode): compositor on iGPU, games on dGPU
    export AQ_DRM_DEVICES="$HOME/.config/hypr/igpu"
    export __NV_PRIME_RENDER_OFFLOAD=1
    export __GLX_VENDOR_LIBRARY_NAME="nvidia"       # GLX games -> nvidia
    export __VK_LAYER_NV_optimus="NVIDIA_only"      # Vulkan games -> nvidia only
    export LIBVA_DRIVER_NAME="iHD"                  # keep video decode on the iGPU
    unset MESA_VK_DEVICE_SELECT DRI_PRIME
    ;;
esac
unset _gfx
